# Environment variables for Critical Infrastructure - Energy Sector AI Chatbot
# Copy this file to .env.local and fill in your actual values

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/critical_infrastructure
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=critical_infrastructure

# Application Settings
DEBUG=False
ENVIRONMENT=development
SECRET_KEY=your_secret_key_here

# Logging
LOG_LEVEL=INFO

# AI Model Configuration
MODEL_NAME=gpt-4
MODEL_TEMPERATURE=0.7

# Feature Flags
ENABLE_CACHING=True
ENABLE_LOGGING=True
